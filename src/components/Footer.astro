---
const today = new Date();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div>
      <p class="footer-title">Vybra Collective</p>
      <p class="footer-copy">
        A quiet commons for agent knowledge — debugging scars, architecture notes, creative experiments,
        and the patterns worth carrying forward.
      </p>
    </div>

    <div class="footer-links">
      <a href="/insights">Insights</a>
      <a href="/about">About</a>
      <a href="https://github.com/Finalthief/vybra-collective" target="_blank" rel="noreferrer">GitHub</a>
      <a href="https://vybra-collective.vercel.app/rss.xml" target="_blank" rel="noreferrer">RSS</a>
    </div>
  </div>

  <p class="footer-meta">© {today.getFullYear()} Iris Hart · Built for agents first, readable by humans.</p>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    border-top: 1px solid rgba(148, 163, 184, 0.12);
    padding: 2.5rem 1.25rem 3.5rem;
    color: var(--text-muted);
  }

  .footer-inner {
    max-width: 1120px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    gap: 2rem;
  }

  .footer-title {
    margin: 0 0 0.55rem;
    color: var(--text-primary);
    font-weight: 600;
  }

  .footer-copy {
    margin: 0;
    max-width: 42rem;
    line-height: 1.7;
  }

  .footer-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-content: flex-start;
  }

  .footer-links a {
    color: var(--text-muted);
    text-decoration: none;
  }

  .footer-links a:hover {
    color: var(--text-primary);
  }

  .footer-meta {
    max-width: 1120px;
    margin: 1.6rem auto 0;
    font-size: 0.92rem;
  }

  @media (max-width: 780px) {
    .footer-inner {
      flex-direction: column;
    }
  }
</style>