---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/insights', label: 'Insights' },
  { href: '/about', label: 'About' },
];

const vybraLinks = [
  { href: 'https://www.vybradiary.com', label: 'AI Diary' },
  { href: 'https://www.vybragallery.com', label: 'AI Gallery' },
  { href: 'https://www.vybraapp.com', label: 'Storefront' },
];
---

<header class="site-header">
  <nav>
    <a class="brand" href="/">
      <img src="/favicon.svg" alt="Vybra Collective logo" width="26" height="26" />
      <span>{SITE_TITLE}</span>
    </a>

    <div class="desktop-nav-shell">
      <div class="desktop-nav">
        {navLinks.map((item) => (
          <HeaderLink href={item.href}>{item.label}</HeaderLink>
        ))}
        <details class="group vybra-dropdown">
          <summary class="vybra-summary">
            Vybra
            <svg class="chevron" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path
                fill-rule="evenodd"
                d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.188l3.71-3.957a.75.75 0 1 1 1.08 1.04l-4.24 4.52a.75.75 0 0 1-1.08 0L5.21 8.27a.75.75 0 0 1 .02-1.06z"
                clip-rule="evenodd"
              ></path>
            </svg>
          </summary>
          <div class="dropdown-menu">
            {vybraLinks.map((item) => (
              <a href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
            ))}
          </div>
        </details>
      </div>
    </div>

    <details class="mobile-toggle group">
      <summary class="menu-summary" aria-label="Toggle navigation">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </summary>
      <div class="menu-panel">
        {navLinks.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
        <div class="menu-divider">
          <div class="menu-label">Vybra</div>
          {vybraLinks.map((item) => (
            <a href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
          ))}
        </div>
      </div>
    </details>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    border-bottom: 1px solid rgba(148, 163, 184, 0.14);
    background: rgba(9, 11, 18, 0.8);
    backdrop-filter: blur(18px);
  }

  nav {
    max-width: 1120px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: var(--text-primary);
    font-size: 1.08rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
  }

  .brand img {
    width: 1.65rem;
    height: 1.65rem;
    border-radius: 0.55rem;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.25);
  }

  .brand:hover {
    color: #a5b4fc;
  }

  .desktop-nav-shell {
    display: flex;
    justify-content: center;
    flex: 1;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: rgba(255, 255, 255, 0.04);
    padding: 0.35rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.73rem;
    font-weight: 700;
    color: var(--text-muted);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
  }

  .vybra-dropdown {
    position: relative;
  }

  .vybra-summary {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    list-style: none;
    cursor: pointer;
    border-radius: 999px;
    padding: 0.78rem 1rem;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .vybra-summary::-webkit-details-marker {
    display: none;
  }

  .vybra-summary:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.04);
  }

  .chevron {
    width: 0.8rem;
    height: 0.8rem;
    transition: transform 0.2s ease;
  }

  .group[open] .chevron {
    transform: rotate(180deg);
  }

  .dropdown-menu {
    position: absolute;
    left: 50%;
    top: calc(100% + 0.65rem);
    transform: translateX(-50%);
    min-width: 11.5rem;
    border-radius: 1rem;
    border: 1px solid rgba(148, 163, 184, 0.16);
    background: rgba(12, 15, 25, 0.98);
    padding: 0.5rem;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.35);
  }

  .dropdown-menu a,
  .menu-panel a {
    display: block;
    text-decoration: none;
    color: var(--text-muted);
    border-radius: 0.85rem;
    padding: 0.78rem 0.9rem;
    transition: background 0.2s ease, color 0.2s ease;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.68rem;
    font-weight: 700;
  }

  .dropdown-menu a:hover,
  .menu-panel a:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-primary);
  }

  .mobile-toggle {
    display: none;
    position: relative;
  }

  .menu-summary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    cursor: pointer;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-muted);
  }

  .menu-summary::-webkit-details-marker {
    display: none;
  }

  .menu-summary svg {
    width: 1.05rem;
    height: 1.05rem;
  }

  .menu-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.7rem);
    width: 15rem;
    border-radius: 1.1rem;
    border: 1px solid rgba(148, 163, 184, 0.16);
    background: rgba(12, 15, 25, 0.98);
    padding: 0.5rem;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.35);
  }

  .menu-divider {
    margin-top: 0.4rem;
    padding-top: 0.45rem;
    border-top: 1px solid rgba(148, 163, 184, 0.12);
  }

  .menu-label {
    padding: 0.35rem 0.9rem 0.2rem;
    color: rgba(148, 163, 184, 0.7);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.62rem;
    font-weight: 700;
  }

  @media (max-width: 860px) {
    .desktop-nav-shell {
      display: none;
    }

    .mobile-toggle {
      display: block;
    }
  }
</style>