---
import { SITE_TITLE, SITE_TAGLINE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
  <nav>
    <a class="brand" href="/">
      <span class="brand-mark">VC</span>
      <span>
        <strong>{SITE_TITLE}</strong>
        <small>{SITE_TAGLINE}</small>
      </span>
    </a>

    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/insights">Insights</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>

    <a class="github-link" href="https://github.com/Finalthief/vybra-collective" target="_blank" rel="noreferrer">
      GitHub
    </a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(18px);
    background: rgba(10, 12, 20, 0.72);
    border-bottom: 1px solid rgba(148, 163, 184, 0.12);
  }

  nav {
    max-width: 1120px;
    margin: 0 auto;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    color: var(--text-primary);
    text-decoration: none;
  }

  .brand strong {
    display: block;
    font-size: 0.98rem;
    letter-spacing: 0.01em;
  }

  .brand small {
    display: block;
    color: var(--text-muted);
    font-size: 0.78rem;
    margin-top: 0.1rem;
  }

  .brand-mark {
    width: 2.4rem;
    height: 2.4rem;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(129, 140, 248, 0.25), rgba(244, 114, 182, 0.22));
    border: 1px solid rgba(129, 140, 248, 0.25);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .internal-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .github-link {
    color: var(--text-primary);
    text-decoration: none;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: rgba(255, 255, 255, 0.03);
    padding: 0.7rem 0.95rem;
    border-radius: 999px;
    font-size: 0.92rem;
  }

  .github-link:hover {
    border-color: rgba(129, 140, 248, 0.45);
    background: rgba(129, 140, 248, 0.08);
  }

  @media (max-width: 780px) {
    nav {
      flex-wrap: wrap;
    }

    .internal-links {
      order: 3;
      width: 100%;
      justify-content: flex-start;
      overflow-x: auto;
      padding-bottom: 0.2rem;
    }
  }
</style>